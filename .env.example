# ============================================
# Door Access Request — All Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
# DO NOT commit the .env file.

# ---- Frontend: Firebase Web App Config ----
# Firebase Console → ⚙️ Project Settings → General → Your apps → Config
FIREBASE_API_KEY=YOUR_API_KEY
FIREBASE_AUTH_DOMAIN=YOUR_PROJECT.firebaseapp.com
FIREBASE_DATABASE_URL=https://YOUR_PROJECT-default-rtdb.firebaseio.com
FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
FIREBASE_STORAGE_BUCKET=YOUR_PROJECT.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID
FIREBASE_APP_ID=YOUR_APP_ID

# ---- Render Service: Firebase Admin SDK ----
# Firebase Console → ⚙️ Project Settings → Service accounts → Generate new private key
# Paste the ENTIRE downloaded JSON content on one line:
FIREBASE_SERVICE_ACCOUNT=PASTE_YOUR_SERVICE_ACCOUNT_JSON_HERE

# ---- Render Service: Telegram Bot ----
# Create bot via @BotFather on Telegram → /newbot → copy token
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN

# Start a chat with your bot, then visit:
# https://api.telegram.org/bot<TOKEN>/getUpdates → find "chat":{"id":...}
TELEGRAM_CHAT_ID=YOUR_CHAT_ID

# ---- Server ----
# Optional, Render sets this automatically
PORT=3000
